# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Servidor ───────────────────────────────────────────────
PORT=3000

# ── Redis (opcional — fallback em memória se não configurado)
REDIS_URL=redis://localhost:6379

# ── Modelo Claude ──────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Memória ────────────────────────────────────────────────
MAX_HISTORY_TURNS=20

# ── Logs ───────────────────────────────────────────────────
LOG_LEVEL=info

# ── Clínica ────────────────────────────────────────────────
CLINIC_PHONE=(83) 9999-9999

# ── Segurança ──────────────────────────────────────────────
# Segredo compartilhado com o n8n (header: x-webhook-secret)
WEBHOOK_SECRET=troque-este-segredo-agora

# Whitelist de números permitidos durante testes (separados por vírgula)
# Deixe vazio para permitir todos
ALLOWED_PHONES=
