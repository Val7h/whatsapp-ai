{
  "name": "Pré-Consulta CTO — Formulário",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "pre-consulta",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "pc-0001",
      "name": "Webhook Pré-Consulta",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "pre-consulta"
    },
    {
      "parameters": {
        "jsCode": "// ── Valida token HMAC-SHA256 ───────────────────────────────────────\nconst crypto = require('crypto');\n\nconst body = $input.first().json;\nconst { token, exp, agendamento_id } = body;\n\nif (!token || !exp || !agendamento_id) {\n  return [{ json: { erro: 'parametros_ausentes', valido: false } }];\n}\n\nconst expNum = parseInt(String(exp));\nif (Date.now() > expNum) {\n  return [{ json: { erro: 'token_expirado', valido: false, ...body } }];\n}\n\nconst secret = $env.FORM_SECRET;\nif (!secret) {\n  throw new Error('FORM_SECRET não configurado nas variáveis de ambiente do n8n');\n}\n\nconst esperado = crypto\n  .createHmac('sha256', secret)\n  .update(`${agendamento_id}:${expNum}`)\n  .digest('hex');\n\nconst valido = token === esperado;\n\nreturn [{ json: { valido, erro: valido ? null : 'token_invalido', ...body } }];\n"
      },
      "id": "pc-0002",
      "name": "Validar Token",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false },
          "conditions": [
            {
              "id": "cond-valido",
              "leftValue": "={{ $json.valido }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equal" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "pc-0003",
      "name": "Token válido?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { ok: false, erro: $json.erro } }}",
        "options": { "responseCode": 401 }
      },
      "id": "pc-0004",
      "name": "Resposta Inválido",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [900, 460]
    },
    {
      "parameters": {
        "jsCode": "// ── Monta linha para o Google Sheets ─────────────────────────────\nconst d = $input.first().json;\nconst agora = new Date().toLocaleString('pt-BR', { timeZone: 'America/Recife' });\n\nconst doencas = Array.isArray(d.doencas_cronicas)\n  ? d.doencas_cronicas.join(', ')\n  : (d.doencas_cronicas || '');\n\nconst exames = Array.isArray(d.exames_urls)\n  ? d.exames_urls.join('\\n')\n  : (d.exames_urls || '');\n\nreturn [{\n  json: {\n    timestamp:              agora,\n    agendamento_id:         d.agendamento_id,\n    token:                  d.token,\n    status:                 'recebido',\n    nome:                   d.nome,\n    telefone:               d.telefone,\n    nascimento:             d.nascimento,\n    cpf:                    d.cpf,\n    cidade:                 d.cidade,\n    bairro:                 d.bairro,\n    profissao:              d.profissao,\n    estado_civil:           d.estado_civil,\n    filhos:                 d.filhos,\n    doencas_cronicas:       doencas,\n    medicacoes:             d.medicacoes,\n    alergias:               d.alergias,\n    cirurgias_anteriores:   d.cirurgias_anteriores,\n    tabagismo:              d.tabagismo,\n    alcool:                 d.alcool,\n    regiao_corpo:           d.regiao_corpo,\n    descricao:              d.descricao,\n    tempo_sintomas:         d.tempo_sintomas,\n    mecanismo:              d.mecanismo,\n    eva:                    d.eva,\n    piora:                  d.piora,\n    melhora:                d.melhora,\n    tratamento_anterior:    d.tratamento_anterior,\n    uso_analgesicos:        d.uso_analgesicos,\n    exames_urls:            exames,\n    forma_pagamento:        d.forma_pagamento,\n    plano_saude:            d.plano_saude || '',\n    pdf_drive_url:          '',\n    // passa adiante para os próximos nodes\n    _pdf_url:               d.pdf_url,\n    _nome:                  d.nome,\n    _telefone:              d.telefone,\n    _data_consulta:         d.data_consulta,\n    _agendamento_id:        d.agendamento_id,\n    _exames_urls_array:     d.exames_urls,\n  }\n}];\n"
      },
      "id": "pc-0005",
      "name": "Montar linha Sheets",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 300]
    },
