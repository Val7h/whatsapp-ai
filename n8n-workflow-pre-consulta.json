            "cirurgias_anteriores":  "={{ $json.cirurgias_anteriores }}",
            "tabagismo":             "={{ $json.tabagismo }}",
            "alcool":                "={{ $json.alcool }}",
            "regiao_corpo":          "={{ $json.regiao_corpo }}",
            "descricao":             "={{ $json.descricao }}",
            "tempo_sintomas":        "={{ $json.tempo_sintomas }}",
            "mecanismo":             "={{ $json.mecanismo }}",
            "eva":                   "={{ $json.eva }}",
            "piora":                 "={{ $json.piora }}",
            "melhora":               "={{ $json.melhora }}",
            "tratamento_anterior":   "={{ $json.tratamento_anterior }}",
            "uso_analgesicos":       "={{ $json.uso_analgesicos }}",
            "exames_urls":           "={{ $json.exames_urls }}",
            "forma_pagamento":       "={{ $json.forma_pagamento }}",
            "plano_saude":           "={{ $json.plano_saude }}",
            "pdf_drive_url":         "={{ $json.pdf_drive_url }}"
          }
        },
        "options": {}
      },
      "id": "pc-0006",
      "name": "Salvar no Google Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "jsCode": "// ── Prepara upload PDF + imagens para o Google Drive ─────────────\nconst d = $input.first().json;\n\nconst pastaBase = $env.GDRIVE_PASTA_PACIENTES || 'pacientes';\n\nreturn [{\n  json: {\n    ...d,\n    _pasta_nome: `${d._agendamento_id}`,\n    _pasta_parent: pastaBase,\n  }\n}];\n"
      },
      "id": "pc-0007",
      "name": "Preparar Drive",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "operation": "createFolder",
        "driveId": { "__rl": true, "value": "My Drive", "mode": "list" },
        "folderId": {
          "__rl": true,
          "value": "={{ $env.GDRIVE_PASTA_PACIENTES_ID }}",
          "mode": "id"
        },
        "name": "={{ $json._pasta_nome }}",
        "options": {}
      },
      "id": "pc-0008",
      "name": "Criar pasta paciente",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [1560, 300]
    },
    {
      "parameters": {
        "operation": "upload",
        "name": "={{ 'pre-consulta_' + $('Montar linha Sheets').item.json._agendamento_id + '.pdf' }}",
        "driveId": { "__rl": true, "value": "My Drive", "mode": "list" },
        "folderId": {
          "__rl": true,
          "value": "={{ $json.id }}",
          "mode": "id"
        },
        "binaryData": false,
        "mediaUrl": "={{ $('Montar linha Sheets').item.json._pdf_url }}",
        "options": { "keepRevisionForever": false }
      },
      "id": "pc-0009",
      "name": "Upload PDF Drive",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [1780, 300]
    },
    {
      "parameters": {
        "jsCode": "// ── Formata mensagem WhatsApp para o médico ──────────────────────\nconst d = $('Montar linha Sheets').item.json;\nconst pdfDrive = $input.first().json.webViewLink || $input.first().json.webContentLink || d._pdf_url;\n\nconst dataConsulta = d._data_consulta\n  ? new Date(d._data_consulta).toLocaleString('pt-BR', {\n      timeZone: 'America/Recife',\n      day: '2-digit', month: '2-digit',\n      hour: '2-digit', minute: '2-digit'\n    })\n  : 'data não informada';\n\nconst alergia = d.alergias && d.alergias.toLowerCase() !== 'nenhuma conhecida' && d.alergias.trim() !== ''\n  ? `\\n⚠️ *Alergia:* ${d.alergias}`\n  : '';\n\nconst msg =\n  `📋 *Pré-consulta recebida*\\n` +\n  `👤 *${d.nome}*\\n` +\n  `📅 ${dataConsulta}\\n` +\n  `🦴 ${d.regiao_corpo} · EVA ${d.eva}/10${alergia}\\n` +\n  `📎 ${pdfDrive}`;\n\nreturn [{ json: { mensagem: msg, pdf_drive_url: pdfDrive, agendamento_id: d._agendamento_id } }];\n"
      },
      "id": "pc-0010",
      "name": "Montar msg médico",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.EVOLUTION_URL }}/message/sendText/{{ $env.EVOLUTION_INSTANCE_MEDICO }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.EVOLUTION_API_KEY }}" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "number",  "value": "={{ $env.MEDICO_TELEFONE }}" },
            { "name": "text",    "value": "={{ $json.mensagem }}" }
          ]
        },
        "options": {}
      },
      "id": "pc-0011",
      "name": "WhatsApp → Médico",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
