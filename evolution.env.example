# ── Evolution API v2 — copie para evolution.env e preencha ──────────────────

# URL pública do servidor (troque pelo IP/domínio da sua VPS em produção)
SERVER_URL=http://localhost:8080

# Chave de autenticação global (crie uma string aleatória segura)
AUTHENTICATION_API_KEY=troque-esta-chave-agora-123456

# Banco: false = sem banco externo (usa SQLite interno da Evolution)
DATABASE_ENABLED=false

# Redis compartilhado com o whatsapp-ai
REDIS_ENABLED=true
REDIS_URI=redis://redis:6379
REDIS_PREFIX_KEY=evolution

# Logs
LOG_LEVEL=ERROR
LOG_COLOR=true

# QR Code
QRCODE_LIMIT=30

# Webhook para n8n (Evolution vai chamar esta URL quando chegar mensagem)
# Troque pela URL do seu n8n depois de subir o serviço
WEBHOOK_GLOBAL_ENABLED=true
WEBHOOK_GLOBAL_URL=http://n8n:5678/webhook/whatsapp-cto
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=false
WEBHOOK_EVENTS_MESSAGES_UPSERT=true
WEBHOOK_EVENTS_MESSAGES_UPDATE=false
WEBHOOK_EVENTS_SEND_MESSAGE=false
WEBHOOK_EVENTS_CONNECTION_UPDATE=false
